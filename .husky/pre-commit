command -v gitleaks >/dev/null 2>&1 || {
  echo "gitleaks is required. Install with: brew install gitleaks"
  exit 1
}

echo "$(date -u) [husky-precommit-hook-gitleaks] start"
gitleaks git --staged --config .gitleaks.toml --redact --verbose --log-level trace
echo "$(date -u) [husky-precommit-hook-gitleaks] end"


echo "$(date -u) [husky-precommit-hook-remark] start"
remark_status=0
for file in $(git diff --cached --name-only --diff-filter=ACMR -- docs blog); do
  case "$file" in
    *.md|*.mdx)
      # Plugins/options come from .remarkrc.mjs. Discard formatted output via
      # stdout redirect instead of `-o /dev/null` (which errors with
      # "Cannot write multiple files to single output" when a file links to
      # other existing files).
      remark --quiet --frail "$file" > /dev/null || remark_status=1
      ;;
  esac
done
echo "$(date -u) [husky-precommit-hook-remark] end"
[ "$remark_status" -eq 0 ] || exit 1

